---
import Base from "../../layouts/Base.astro";
import BombermanGame from "../../components/BombermanGame.tsx";
---

<Base title="Bomberman" description="A classic Bomberman game ported from a high-school Java project.">
  <div class="game-page">
    <h1>Bomberman</h1>
    <p>A 2-player bomberman game — originally <a href="https://github.com/wgranados/games/tree/master/bomberman" target="_blank" rel="noopener noreferrer">written in Java</a>, now playable in the browser.</p>
    <BombermanGame client:only="react" />
  </div>
</Base>

<style>
  .game-page {
    padding: 2rem 0;
  }

  .game-page h1 {
    margin-bottom: 0.25rem;
  }

  .game-page > p {
    color: #979797;
    margin-bottom: 1.5rem;
  }
</style>
