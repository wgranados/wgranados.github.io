---
import Base from "../../layouts/Base.astro";
import ArqanoidGame from "../../components/ArqanoidGame.tsx";
---

<Base title="Arqanoid" description="A brick-breaker game ported from a high-school Java project.">
  <div class="game-page">
    <h1>Arqanoid</h1>
    <p>A brick-breaker game — originally <a href="https://github.com/wgranados/games/tree/master/arqanoid-brick-breaker" target="_blank" rel="noopener noreferrer">written in Java</a>, now playable in the browser.</p>
    <ArqanoidGame client:only="react" />
  </div>
</Base>

<style>
  .game-page {
    padding: 2rem 0;
  }

  .game-page h1 {
    margin-bottom: 0.25rem;
  }

  .game-page > p {
    color: #979797;
    margin-bottom: 1.5rem;
  }
</style>
