{
  "private": true,
  "description": "Root tooling for wgranados.github.io (Pagefind search index after Jekyll + Astro build)",
  "scripts": {
    "pagefind": "pagefind --site _site --quiet --glob \"blog/**/*.html\"",
    "pagefind:watch": "chokidar \"_site/blog/**/*.html\" --ignore \"_site/pagefind/**\" --debounce 3000 -c \"npm run pagefind\""
  },
  "devDependencies": {
    "chokidar-cli": "^3.0.0",
    "pagefind": "^1.5.0"
  }
}
