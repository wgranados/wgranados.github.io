---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "Games and experiments by William Granados." } = Astro.props;
const base = import.meta.env.BASE_URL;
const siteUrl = import.meta.env.DEV ? "http://localhost:4000" : "https://wgma.ca";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} · William Granados</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" sizes="32x32" href={`${siteUrl}/assets/favicon.ico`} />
    <link rel="stylesheet" href={`${base}fonts/fonts.css`} />
  </head>
  <body>
    <nav class="nav">
      <div class="nav-container">
        <a href={siteUrl}><h2 class="nav-title">Home</h2></a>
        <ul>
          <li><a href={`${siteUrl}/about`}>About</a></li>
          <li><a href={`${siteUrl}/blog/`}>Blog</a></li>
          <li><a href={`${siteUrl}/tutorials`}>Tutorials</a></li>
          <li><a href={`${siteUrl}/work`}>Work</a></li>
          <li><a href={`${base}/`} class="active">Arcade</a></li>
        </ul>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <footer>
      <span>
        &copy; {new Date().getFullYear()} William Granados. Made with
        <a href="https://astro.build/">Astro</a> +
        <a href="https://react.dev/">React</a>.
      </span>
    </footer>
  </body>
</html>

<style is:global>
  *,
  *::before,
  *::after {
    box-sizing: border-box;
    line-height: 1.5;
  }

  html,
  body {
    color: rgba(255, 255, 255, 0.7);
    margin: 0;
    padding: 0;
    background: #0a0a1a;
  }

  html {
    font-family: "Libre Baskerville", "Times New Roman", Times, serif;
    font-size: 14px;
    overflow-y: scroll;
  }

  @media (min-width: 600px) {
    html {
      font-size: 16px;
    }
  }

  h1,
  h2,
  h3,
  h4,
  h5,
  h6 {
    color: #fff;
    font-family: "Helvetica Neue", "Segoe UI", Helvetica, Arial, sans-serif;
    line-height: normal;
  }

  a {
    color: #48dbfb;
    text-decoration: none;
  }

  img {
    display: block;
    margin: 0 0 1rem;
    max-width: 100%;
  }

  main,
  footer,
  .nav-container {
    display: block;
    margin: 0 auto;
    max-width: 800px;
    width: 80%;
  }

  .nav {
    background: rgba(10, 10, 26, 0.95);
    border-bottom: 1px solid rgba(72, 219, 251, 0.1);
    backdrop-filter: blur(12px);
    overflow: auto;
  }

  .nav-container {
    margin: 1rem auto;
    position: relative;
    text-align: center;
  }

  .nav-title {
    transition: all 0.2s ease-out;
    color: rgba(255, 255, 255, 0.7);
    display: inline-block;
    margin: 0;
    padding-right: 0.2rem;
  }

  .nav-title:hover,
  .nav-title:focus {
    color: #48dbfb;
    opacity: 1;
  }

  .nav ul {
    list-style-type: none;
    margin: 1rem 0 0;
    padding: 0;
    text-align: center;
  }

  .nav li {
    transition: all 0.2s ease-out;
    display: inline-block;
    opacity: 0.5;
    padding: 0 2rem 0 0;
  }

  .nav li:last-child {
    padding-right: 0;
  }

  .nav li:hover,
  .nav li:focus {
    opacity: 1;
  }

  .nav a {
    color: rgba(255, 255, 255, 0.7);
    font-family: "Helvetica Neue", "Segoe UI", Helvetica, Arial, sans-serif;
    transition: color 0.2s ease;
  }

  .nav a:hover {
    color: #48dbfb;
  }

  .nav a.active {
    opacity: 1;
    font-weight: bold;
    color: #48dbfb;
    text-shadow: 0 0 12px rgba(72, 219, 251, 0.4);
  }

  @media (min-width: 600px) {
    .nav-container {
      text-align: left;
    }

    .nav ul {
      bottom: 0;
      position: absolute;
      right: 0;
    }
  }

  footer {
    font-family: Palatino, "Palatino LT STD", "Palatino Linotype",
      "Book Antiqua", Georgia, serif;
    padding: 2rem 0;
    text-align: center;
    border-top: 1px solid rgba(72, 219, 251, 0.08);
  }

  footer span {
    color: rgba(255, 255, 255, 0.3);
    font-size: 0.8rem;
  }

  footer a {
    color: rgba(72, 219, 251, 0.5);
    transition: color 0.2s ease;
  }

  footer a:hover {
    color: #48dbfb;
  }
</style>
