---
import Base from "../../layouts/Base.astro";
import SampleGame from "../../components/SampleGame.tsx";
---

<Base title="Sample Game" description="A simple click-counter game to test the Astro + React setup.">
  <div class="game-page">
    <h1>Sample Game</h1>
    <p>A trivial click counter — replace this with a real game later.</p>
    <SampleGame client:load />
  </div>
</Base>

<style>
  .game-page {
    padding: 2rem 0;
  }

  .game-page h1 {
    margin-bottom: 0.25rem;
    font-family: "Syne", sans-serif;
    font-weight: 800;
    text-shadow: 0 0 12px rgba(72, 219, 251, 0.3);
  }

  .game-page > p {
    color: rgba(255, 255, 255, 0.4);
  }
</style>
