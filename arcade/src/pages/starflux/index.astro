---
import Base from "../../layouts/Base.astro";
import StarfluxGame from "../../components/StarfluxGame.tsx";
---

<Base title="Starflux" description="A vertical-scrolling space shooter ported from a Verilog project.">
  <div class="game-page">
    <h1>Starflux</h1>
    <p>A space shooter — originally <a href="https://github.com/wgranados/Starflux" target="_blank" rel="noopener noreferrer">written in Verilog</a>, now playable in the browser.</p>
    <StarfluxGame client:only="react" />
  </div>
</Base>

<style>
  .game-page {
    padding: 2rem 0;
  }

  .game-page h1 {
    margin-bottom: 0.25rem;
    font-family: "Syne", sans-serif;
    font-weight: 800;
    text-shadow: 0 0 12px rgba(72, 219, 251, 0.3);
  }

  .game-page > p {
    color: rgba(255, 255, 255, 0.4);
    margin-bottom: 1.5rem;
  }

  .game-page > p a {
    color: #48dbfb;
  }
</style>
